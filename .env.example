# --- Express server ---
PORT=8080

# --- OpenClaw gateway connection ---
# Gateway on host: ws://127.0.0.1:18789. Express-in-Docker (Desktop): often ws://host.docker.internal:18789
OPENCLAW_GATEWAY_URL=ws://localhost:18789
# Must match OPENCLAW_GATEWAY_TOKEN set on the gateway side
OPENCLAW_GATEWAY_TOKEN=replace-with-the-token-from-your-gateway

# Max characters of spreadsheet TSV injected into the agent prompt (default 24000)
# Lower this if Groq returns TPM / payload errors.
# MAX_EXCEL_CONTEXT_CHARS=24000
